node_modules/
.next/
.expo/
dist/
build/
out/

# ── Environment (asla repoya girmesin) ───────────────────────────────────────
.env
.env.local
.env.*.local

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

