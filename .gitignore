# ── Runtime state (her kullanıcıya özel, repoya girmiyor) ─────────────────────
.state/
.state/*.md

# ── Aktif projeler ve arşiv (gerçek proje içeriği) ───────────────────────────
projects/
archive/

# ── Cross-platform job queue ──────────────────────────────────────────────────
mission/

# ── User-specific MCP config (copy .mcp.example.json → .mcp.json) ─────────────
.mcp.json

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/

